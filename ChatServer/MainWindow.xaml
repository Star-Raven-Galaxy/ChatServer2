<Window x:Class="ChatServerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат Сервер" Height="450" Width="650">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="Порт:" VerticalAlignment="Center"/>
            <TextBox x:Name="PortBox" Text="5000" Width="60" Margin="5,0"/>
            <Button x:Name="StartBtn" Content="Запустить" Width="80" Margin="5,0" Click="StartBtn_Click"/>
            <Button x:Name="StopBtn" Content="Остановить" Width="80" IsEnabled="False" Click="StopBtn_Click"/>
            <TextBlock x:Name="StatusText" Text="Сервер остановлен" VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
            <Label Content="Клиентов:"/>
            <TextBlock x:Name="ClientCountText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <ListBox x:Name="LogList" Grid.Row="1" Background="Black" Foreground="LightGreen" FontFamily="Consolas"/>

        <Button Grid.Row="2" Content="Очистить лог" HorizontalAlignment="Left" Click="ClearLogBtn_Click"/>
    </Grid>
</Window>