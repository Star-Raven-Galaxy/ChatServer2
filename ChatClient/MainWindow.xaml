<Window x:Class="ChatClientApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат Клиент" Height="529" Width="700">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="5">
            <StackPanel>
                <WrapPanel Margin="0,0,0,5">
                    <Label Content="IP:" Width="30"/>
                    <TextBox x:Name="IpBox" Text="127.0.0.1" Width="100" Margin="2"/>
                    <Label Content="Порт:" Width="40"/>
                    <TextBox x:Name="PortBox" Text="5000" Width="60" Margin="2"/>
                    <Label Content="Ник:" Width="40"/>
                    <TextBox x:Name="NickBox" Width="120" Margin="2"/>
                    <Button x:Name="ConnectBtn" Content="Подключиться" Width="100" Margin="10,0,0,0" Click="ConnectBtn_Click"/>
                    <Button x:Name="DisconnectBtn" Content="Отключиться" Width="100" Margin="5,0,0,0" IsEnabled="False" Click="DisconnectBtn_Click"/>
                </WrapPanel>
                <TextBlock x:Name="StatusText" Text="Не подключен" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="MessagesList" Grid.Column="0" Margin="0,0,5,0"/>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Content="Пользователи онлайн:" FontWeight="Bold"/>
                <ListBox x:Name="UsersList" Grid.Row="1"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MessageBox" Grid.Column="0" Margin="0,0,5,0" IsEnabled="False" KeyDown="MessageBox_KeyDown"/>
            <Button x:Name="SendBtn" Content="Отправить" Width="100" IsEnabled="False" Click="SendBtn_Click" RenderTransformOrigin="0.507,2.202"/>
        </Grid>
    </Grid>
</Window>